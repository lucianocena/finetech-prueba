const express = require('express');
const app = express();
const PORT = process.env.PORT || 3000;

app.use(express.json());

// Ruta simple para verificar que el servidor vive
app.get('/', (req, res) => {
  res.send('¡Servidor de Webhook Activo!');
});

// El endpoint que Meta va a buscar para validar
app.get('/webhook', (req, res) => {
  const mode = req.query['hub.mode'];
  const token = req.query['hub.verify_token'];
  const challenge = req.query['hub.challenge'];

  // ACÁ: Cambiá 'fintechgas' por el token que vayas a usar en Meta
  if (mode && token === 'fintechgas') {
    res.status(200).send(challenge);
  } else {
    res.status(403).send('Forbidden');
  }
});

app.listen(PORT, () => {
  console.log(`Servidor corriendo en puerto ${PORT}`);
});
